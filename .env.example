# Required
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
TELEGRAM_CHAT_ID=123456789
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# REQUIRED for HF Spaces — proxy for api.telegram.org
# HF Spaces BLOCKS api.telegram.org at the TLS/SNI level.
# Deploy proxy/cloudflare-worker.js on Cloudflare Workers (free, 5 min),
# then set this to your worker URL. Without this, NO messages will reach Telegram.
TELEGRAM_API_BASE=https://your-tg-proxy.your-name.workers.dev

# Recommended (enables persistent state sync across HF Space restarts)
HF_TOKEN=hf_your_huggingface_access_token_here
HF_STATE_REPO=your-username/thedeepview-bot-state

# Optional — defaults shown
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GEMINI_DAILY_LIMIT=20
GEMINI_SAFETY_THRESHOLD=18
GEMINI_BATCH_MAX_ARTICLES=15
# SOURCES_JSON= see README for shape
# DATA_DIR=/data
# PORT=7860
